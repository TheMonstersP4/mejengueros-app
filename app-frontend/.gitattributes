# Normalize text files to LF for cross-platform development.
* text=auto eol=lf

# Windows command scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts should keep LF.
*.sh text eol=lf

# Binary assets must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.keystore binary
*.jks binary
*.p12 binary
*.mobileprovision binary
