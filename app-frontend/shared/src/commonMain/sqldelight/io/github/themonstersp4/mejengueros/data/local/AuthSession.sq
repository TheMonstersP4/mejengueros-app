CREATE TABLE AuthSession (
    id INTEGER NOT NULL PRIMARY KEY CHECK (id = 1),
    sub TEXT NOT NULL,
    email TEXT NOT NULL,
    displayName TEXT,
    provider TEXT
);

selectSession:
SELECT sub, email, displayName, provider
FROM AuthSession
WHERE id = 1;

upsertSession:
INSERT OR REPLACE INTO AuthSession(
    id,
    sub,
    email,
    displayName,
    provider
)
VALUES (1, ?, ?, ?, ?);

clearSession:
DELETE FROM AuthSession;
