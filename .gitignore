# Terraform runtime files
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/*.tfplan
**/tfplan
**/crash.log
**/crash.*.log
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Environment values
**/*.tfvars
**/*.tfvars.json
**/*.backend.hcl
!**/*.tfvars.example
!**/*.backend.hcl.example

# Local secrets and generated files
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Node.js runtime and build output
node_modules/
**/node_modules/
dist/
**/dist/
coverage/
**/coverage/
**/bin/
*.tsbuildinfo
app-backend/api/src/generated/prisma/
app-backend/api/.lambda/
app-backend/api/.local/

# Local agent workspaces
.atl/
.codegraph/
.pi/
.skills/
**/.skills/

# Keep every shared project skill versioned while ignoring other local agent workspace files.
.agents/*
**/.agents/*
!.agents/skills/
!.agents/skills/**
!**/.agents/skills/
!**/.agents/skills/**
!skills/
!skills/**
!**/skills/
!**/skills/**

# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
