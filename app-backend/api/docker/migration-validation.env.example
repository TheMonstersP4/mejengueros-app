# Copy this file to migration-validation.env.local before running docker:migration-db:* scripts.
# Keep the local file uncommitted. Replace placeholder values with disposable local-only credentials.
MIGRATION_DB_NAME=mejengueros_migration_validation
MIGRATION_DB_USER=mejengueros_local
MIGRATION_DB_PASSWORD=change_me_local_only
MIGRATION_DB_PORT=54329
DATABASE_URL=postgresql://<local-user>:<local-password>@localhost:<local-port>/<local-database>?schema=mejengueros_dev
