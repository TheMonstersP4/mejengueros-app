{
  "name": "backend-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predb:seed": "npm run prisma:generate",
    "db:seed": "prisma db seed",
    "docker:migration-db:up": "docker compose --env-file docker/migration-validation.env.local -f docker/docker-compose.migration-validation.yml up -d",
    "docker:migration-db:down": "docker compose --env-file docker/migration-validation.env.local -f docker/docker-compose.migration-validation.yml down",
    "docker:migration-db:reset": "docker compose --env-file docker/migration-validation.env.local -f docker/docker-compose.migration-validation.yml down -v --remove-orphans",
    "guard:focused-tests": "node ./scripts/ensure-no-focused-tests.cjs",
    "prebuild": "npm run prisma:generate",
    "build": "nest build",
    "start": "nest start",
    "prestart": "npm run prisma:generate",
    "start:dev": "nest start --watch",
    "prestart:dev": "npm run prisma:generate",
    "lint": "npm run guard:focused-tests && eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lambda:package:reservation-completion": "node ./scripts/package-reservation-completion-lambda.mjs",
    "lambda:package:websocket": "node ./scripts/package-websocket-lambda.mjs",
    "dev:notifications:review-prompts": "ts-node -r tsconfig-paths/register ./scripts/create-dev-review-prompt-notifications.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "pretest": "npm run guard:focused-tests && npm run prisma:generate",
    "test": "jest --passWithNoTests",
    "test:ci": "npm test -- --runInBand --forceExit",
    "test:reservation-completion:db": "jest --config ./jest.integration.config.cjs test/integration/prisma-reservation.repository.db.spec.ts --runInBand --detectOpenHandles",
    "test:ci:diagnose": "npm test -- --runInBand --detectOpenHandles --openHandlesTimeout=10000",
    "pretest:integration": "npm run guard:focused-tests && npm run prisma:generate",
    "test:integration": "jest --config ./jest.integration.config.cjs --passWithNoTests --detectOpenHandles",
    "pretest:cov": "npm run guard:focused-tests && npm run prisma:generate",
    "test:cov": "jest --coverage --passWithNoTests",
    "pretest:e2e": "npm run guard:focused-tests && npm run prisma:generate",
    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1053.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/client-secrets-manager": "^3.1065.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-presigned-post": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "aws-jwt-verify": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.4.7",
    "nestjs-pino": "^4.0.0",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
